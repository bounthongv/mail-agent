# Mail Agent Server Configuration Example
# ========================================
# Copy this file to .env and fill in your actual values

# AI Provider API Keys
# --------------------
# Get Gemini API key: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get OpenRouter API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Get HuggingFace token: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_token_here

# Get NVIDIA API key: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# Telegram Bot Token
# ------------------
# Create bot via @BotFather on Telegram, get token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Local AI URLs (Optional - for Ollama fallback)
# ----------------------------------------------
# Windows server URL for Ollama
WINDOWS_AI_URL=http://localhost:11434/api/generate

# Ubuntu server URL for Ollama
UBUNTU_AI_URL=http://localhost:11434/api/generate

# Server Settings (Optional)
# --------------------------
# Host to bind the API server (default: 0.0.0.0)
SERVER_HOST=0.0.0.0

# Port for the API server (default: 8000)
SERVER_PORT=8000

# Debug mode (default: false)
SERVER_DEBUG=false
